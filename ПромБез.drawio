        <mxCell id="-WssIlFQG6i6GCGSxKV0-43" parent="-WssIlFQG6i6GCGSxKV0-42" style="whiteSpace=wrap;html=1;rounded=1;fontSize=14;" value="Система составляет список записей" vertex="1">
