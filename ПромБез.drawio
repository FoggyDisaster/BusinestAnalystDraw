        <mxCell id="RIRhulhHAlF5B4grZ4R7-15" parent="RIRhulhHAlF5B4grZ4R7-31" style="whiteSpace=wrap;html=1;rounded=1;" value="Требуется обучение и аттестация" vertex="1">
